# ── LLM Provider (at least one required) ────────────────────────────────────
# If OPENROUTER_API_KEY is set, OpenRouter is used (https://openrouter.ai/api/v1).
# Otherwise GROQ_API_KEY is used (https://api.groq.com/openai/v1).
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ── GitHub (required) ────────────────────────────────────────────────────────
# Classic personal access token with read-only repository permissions,
# used to fetch pull requests and merged PR history.
GITHUB_TOKEN=

# ── Model (optional) ─────────────────────────────────────────────────────────
# Model to use. Defaults to:
#   "google/gemini-2.5-flash"   when OPENROUTER_API_KEY is set
#   "llama-3.3-70b-versatile"   otherwise (Groq)
MODEL=

# ── Server (optional) ────────────────────────────────────────────────────────
# Port the Express server listens on. Defaults to 3000.
PORT=3000

# ── Database (required) ──────────────────────────────────────────────────────
# MongoDB connection string used by better-auth to store users/sessions.
# The server fails to start if this is empty.
# e.g. mongodb+srv://user:pass@cluster.mongodb.net  or  mongodb://localhost:27017
MONGODB_URL=

# ── Authentication / better-auth (required) ──────────────────────────────────
# Secret used to sign sessions. Generate one, e.g.:  openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of THIS backend (used for auth callbacks / cookies).
# Local: http://localhost:3000   Production: https://prhawk-1.onrender.com
BETTER_AUTH_URL=http://localhost:3000

# ── Legacy access key (optional) ─────────────────────────────────────────────
# Pre-auth access key checked via the x-access-key header. Leave empty.
APP_SECRET=
